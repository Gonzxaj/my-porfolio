---
import Icon_Home from './icons/icon-home.astro';
import Icon_User from './icons/icon-user.astro';
import Icon_Project from './icons/icon-project.astro';
import Icon_Contact from './icons/icon-contact.astro';

import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const otherLang = lang === 'es' ? 'en' : 'es';
const otherLangUrl = lang === 'es' ? '/en' : '/';
---

<!-- Desktop: floating pill (left side) -->
<div class="container-navbar mx-4 z-10">
    <a href="#" class="toggleBox" aria-label="Open navbar">
        <span class="icon"></span>
    </a>
    <ul class="navItems">
        <li>
            <a href="#home" class="navLink">
                <i style="--i:1"><Icon_Home/></i>
                <span style="--g:1">{t('nav.home')}</span>
            </a>
        </li>
        <li>
            <a href="#about" class="navLink">
                <i style="--i:2"><Icon_User/></i>
                <span style="--g:2">{t('nav.about')}</span>
            </a>
        </li>
        <li>
            <a href="#proyectos" class="navLink">
                <i style="--i:3"><Icon_Project/></i>
                <span style="--g:3">{t('nav.projects')}</span>
            </a>
        </li>
        <li>
            <a href="#contacto" class="navLink">
                <i style="--i:4"><Icon_Contact/></i>
                <span style="--g:4">{t('nav.contact')}</span>
            </a>
        </li>
        <li>
            <a href={otherLangUrl} class="navLink">
                <i style="--i:5">
                    <img src={`/icons/flags/${otherLang === 'en' ? 'uk' : 'spain'}.png`} alt={otherLang} width="22" height="22" style="border-radius: 3px; object-fit: cover;" />
                </i>
                <span style="--g:5">{otherLang.toUpperCase()}</span>
            </a>
        </li>
    </ul>
</div>

<!-- Mobile: bottom navigation bar -->
<nav class="mobile-nav">
    <a href="#home" class="mobile-nav-item">
        <Icon_Home/>
        <span>{t('nav.home')}</span>
    </a>
    <a href="#about" class="mobile-nav-item">
        <Icon_User/>
        <span>{t('nav.about')}</span>
    </a>
    <a href="#proyectos" class="mobile-nav-item">
        <Icon_Project/>
        <span>{t('nav.projects')}</span>
    </a>
    <a href="#contacto" class="mobile-nav-item">
        <Icon_Contact/>
        <span>{t('nav.contact')}</span>
    </a>
    <a href={otherLangUrl} class="mobile-nav-item">
        <img src={`/icons/flags/${otherLang === 'en' ? 'uk' : 'spain'}.png`} alt={otherLang} width="24" height="24" style="border-radius: 4px; object-fit: cover;" />
        <span>{otherLang.toUpperCase()}</span>
    </a>
</nav>

<style>
/* ── Desktop floating pill ── */
    .container-navbar {
        display: none;
    }

    @media (min-width: 768px) {
        .container-navbar {
            display: block;
            top: 30%;
            height: 70px;
            width: 70px;
            background-color: white;
            border-radius: 50px;
            position: fixed;
            transition: 0.4s ease;
        }
    }

    .container-navbar.active {
        height: 500px;
    }

    .container-navbar.active .navItems {
        visibility: visible;
    }

    .toggleBox {
        position: relative;
        display: block;
        height: 70px;
        width: 70px;
        border-radius: 50px;
    }

    .icon {
        position: absolute;
        height: 4px;
        width: 35px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: #161d2c;
        border-radius: 50px;
    }

    .toggleBox.active .icon {
        width: 0;
    }

    .icon::before,
    .icon::after {
        position: absolute;
        content: '';
        height: 4px;
        width: 35px;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: #161d2c;
        border-radius: 50px;
        transition: 0.3s;
    }

    .icon::before { top: 12px; }
    .icon::after  { bottom: 8px; }

    .toggleBox.active .icon::before {
        width: 40px;
        transform-origin: right;
        transform: translate(-25px, 4px) rotate(45deg);
    }

    .toggleBox.active .icon::after {
        width: 40px;
        transform-origin: right;
        transform: translate(-25px, -6px) rotate(-45deg);
    }

    .navItems {
        display: flex;
        flex-direction: column;
        visibility: hidden;
        padding-inline-start: 21px !important;
    }

    .navLink {
        display: flex;
        align-items: center;
    }

    li { list-style: none; }

    li a {
        text-transform: uppercase;
        color: #161d2c;
    }

    li a i {
        position: relative;
        display: block;
        font-size: 18px;
        padding: 35px 5px;
        width: 100%;
        text-align: center;
        transform: scale(0);
    }

    .container-navbar.active .navItems li a i {
        transform: scale(1);
        transition: 0.4s ease;
        transition-delay: calc(0.08s * var(--i));
    }

    .container-navbar.active .navItems li:hover a i {
        transition: 0.2s ease;
        color: #26D07C;
    }

    li a span {
        position: absolute;
        color: #fff;
        padding-left: 2rem;
        font-weight: 500;
        letter-spacing: 2px;
        margin-left: 10px;
    }

    .container-navbar.active .navItems li a span {
        transform: translateX(15px);
        transition: 0.4s ease;
        transition-delay: calc(0.08s * var(--g));
    }

    .container-navbar.active .navItems li:hover a span {
        transform: translateX(30px);
        transition: 0.2s ease;
        color: #26D07C;
    }

/* ── Mobile bottom bar ── */
    .mobile-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 50;
        display: flex;
        justify-content: space-around;
        align-items: center;
        background: rgba(15, 15, 25, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 8px 0 calc(8px + env(safe-area-inset-bottom));
        height: 64px;
    }

    @media (min-width: 768px) {
        .mobile-nav {
            display: none;
        }
    }

    .mobile-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
        color: #6b7280;
        text-decoration: none;
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.03em;
        padding: 4px 10px;
        border-radius: 12px;
        transition: color 0.2s ease;
        flex: 1;
    }

    .mobile-nav-item svg,
    .mobile-nav-item :global(svg) {
        width: 22px;
        height: 22px;
        fill: currentColor;
    }

    .mobile-nav-item:hover,
    .mobile-nav-item.active {
        color: #818cf8;
    }
</style>

<script>
    const toggleClick = document.querySelector('.toggleBox');
    const container_navbar = document.querySelector('.container-navbar');

    toggleClick?.addEventListener('click', (event) => {
        event.preventDefault();
        toggleClick.classList.toggle('active');
        container_navbar?.classList.toggle('active');
    });

    // Highlight active mobile nav item on scroll
    const sectionIds = ['home', 'about', 'proyectos', 'contacto'];
    const mobileItems = document.querySelectorAll('.mobile-nav-item');

    function updateActive() {
        const atBottom = window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 10;

        if (atBottom) {
            mobileItems.forEach(item => {
                item.classList.toggle('active', item.getAttribute('href') === '#contacto');
            });
            return;
        }

        const scrollY = window.scrollY + window.innerHeight / 3;
        let current = sectionIds[0];

        for (const id of sectionIds) {
            const el = document.getElementById(id);
            if (el && el.offsetTop <= scrollY) {
                current = id;
            }
        }

        mobileItems.forEach(item => {
            const href = item.getAttribute('href');
            item.classList.toggle('active', href === `#${current}`);
        });
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
</script>
