---
import { projects } from '../data/projects';
import type { Project } from '../data/projects';

interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const list = projects[lang];

const i18n = {
  es: { title: 'Proyectos', viewResponsibilities: 'Ver responsabilidades', viewSite: 'Ver sitio →', repo: 'Repositorio →' },
  en: { title: 'Projects', viewResponsibilities: 'View responsibilities', viewSite: 'View site →', repo: 'Repository →' },
};

const t = i18n[lang];
---

<section id="proyectos" class="container mx-auto py-16 px-4">
    <h2 class="text-3xl font-bold text-white mb-12 text-center">{t.title}</h2>

    <div class="max-w-3xl mx-auto flex flex-col gap-6">
        {list.map((project: Project) => (
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 hover:border-indigo-500 transition-colors duration-300">
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-1">
                    <h3 class="text-xl font-bold text-white">{project.title}</h3>
                </div>
                <p class="text-indigo-400 font-semibold text-sm mb-3">{project.role}</p>
                <p class="text-gray-300 text-sm mb-4">{project.summary}</p>

                <details class="mb-4 group">
                    <summary class="cursor-pointer text-sm text-indigo-400 hover:text-indigo-300 select-none list-none flex items-center gap-1">
                        <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        {t.viewResponsibilities}
                    </summary>
                    <ul class="mt-3 space-y-1.5 pl-4 border-l border-gray-700">
                        {project.responsibilities.map((r: string) => (
                            <li class="text-sm text-gray-400 before:content-['·'] before:mr-2 before:text-indigo-500">{r}</li>
                        ))}
                    </ul>
                </details>

                <div class="flex flex-wrap gap-2 mb-3">
                    {project.technologies.map((tech: import('../data/projects').Technology) => (
                        <span class="flex items-center gap-1.5 text-xs bg-gray-700 text-gray-300 px-3 py-1.5 rounded-full">
                            {tech.icon && (
                                <img src={`/icons/tech/${tech.icon}.svg`} alt={tech.name} width="14" height="14" class="w-3.5 h-3.5 object-contain" />
                            )}
                            {tech.name}
                        </span>
                    ))}
                </div>

                {(project.url || project.repo) && (
                    <div class="flex gap-4">
                        {project.url && (
                            <a href={project.url} target="_blank" rel="noopener noreferrer"
                               class="text-sm text-indigo-400 hover:text-indigo-300 font-semibold transition-colors">
                                {t.viewSite}
                            </a>
                        )}
                        {project.repo && (
                            <a href={project.repo} target="_blank" rel="noopener noreferrer"
                               class="text-sm text-gray-400 hover:text-gray-300 font-semibold transition-colors">
                                {t.repo}
                            </a>
                        )}
                    </div>
                )}
            </div>
        ))}
    </div>
</section>
